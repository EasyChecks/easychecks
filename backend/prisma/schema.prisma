generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums (ตัวเลือก) ---
enum Role {
  SUPERADMIN
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  RESIGNED
}

enum AttendanceStatus {
  ON_TIME
  LATE
  ABSENT
}

enum LeaveType {
  SICK
  PERSONAL
  VACATION
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

