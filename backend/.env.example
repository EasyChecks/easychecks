# Pooler connection - ใช้สำหรับ app runtime (fast, pooled connections)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection - ใช้สำหรับ migrations/push
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# Supabase Storage
SUPABASE_BUCKET_NAME="easycheck-bucket"

# Supabase Config
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
# Resend — Email Service (https://resend.com)
# สร้าง API key ได้ที่ Resend dashboard → API Keys
RESEND_API_KEY="re_your_api_key_here"
# อีเมลผู้ส่ง — ถ้ายังไม่มี domain ให้ใช้ onboarding@resend.dev (ส่งได้เฉพาะอีเมลที่ verify ใน dashboard)
MAIL_FROM="EasyCheck <onboarding@resend.dev>"