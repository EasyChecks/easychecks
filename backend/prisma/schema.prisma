generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId                                                  Int                  @id @default(autoincrement()) @map("user_id")
  employeeId                                              String               @unique @map("employee_id")
  title                                                   Title                @default(MR) @map("title")
  firstName                                               String               @map("first_name")
  lastName                                                String               @map("last_name")
  nickname                                                String?              @map("nickname")
  gender                                                  Gender               @default(MALE)
  nationalId                                              String               @unique @map("national_id")
  emergent_tel                                            String               @map("emergent_tel")
  emergent_first_name                                     String               @map("emergent_first_name")
  emergent_last_name                                      String               @map("emergent_last_name")
  emergent_relation                                       String               @map("emergent_relation")
  phone                                                   String               @map("phone")
  email                                                   String               @unique
  password                                                String?              @map("password")
  adminPassword                                           String?              @map("admin_password")
  avatarUrl                                               String?              @map("avatar_url")
  birthDate                                               DateTime?            @map("birth_date") @db.Date
  department                                              String?              @map("department")
  position                                                String?              @map("position")
  bloodType                                               String?              @map("blood_type")
  branchId                                                Int?                 @map("branch_id")
  role                                                    Role                 @default(USER)
  status                                                  UserStatus           @default(ACTIVE)
  createdAt                                               DateTime             @default(now()) @map("created_on")
  updatedAt                                               DateTime             @default(now()) @updatedAt @map("updated_on")
  attendances                                             Attendance[]
  auditLogs                                               AuditLog[]
  branchesCreated                                         Branch[]             @relation("BranchCreator")
  approvalActions                                         ApprovalAction[]
  EventParticipants                                       EventParticipant[]
  events_events_created_by_user_idTousers                 Event[]              @relation("events_created_by_user_idTousers")
  late_requests_late_requests_user_idTousers              LateRequest[]        @relation("late_requests_user_idTousers")
  leaveRequests                                           LeaveRequest[]       @relation("Requester")
  locationsCreated                                        Location[]           @relation("LocationCreator")
  notifications                                           Notification[]
  shifts                                                  Shift[]              @relation("UserShift")
  branch                                                  Branch?              @relation("UserBranch", fields: [branchId], references: [branchId])
  sessions                                                Session[]
  
  // Announcement Relations
  createdAnnouncements                                    Announcement[]       @relation("AnnouncementCreator")
  sentAnnouncements                                       Announcement[]       @relation("AnnouncementSender")
  announcementRecipients                                  AnnouncementRecipient[]

  @@map("users")
}

model Branch {
  branchId           Int                  @id @default(autoincrement()) @map("branch_id")
  name               String               @map("name")
  code               String               @unique @map("code")
  address            String?              @map("address")
  createdByUserId    Int?                 @map("created_by_user_id")
  creator            User?                @relation("BranchCreator", fields: [createdByUserId], references: [userId])
  EventParticipants  EventParticipant[]
  users              User[]               @relation("UserBranch")

  @@map("branches")
}

model Attendance {
  attendanceId     Int              @id @default(autoincrement()) @map("attendance_id")
  userId           Int              @map("user_id")
  shiftId          Int?             @map("shift_id")
  locationId       Int?             @map("location_id")
  checkIn          DateTime         @default(now()) @map("check_in")
  checkInPhoto     String?          @map("check_in_photo")
  checkInLat       Float?           @map("check_in_lat")
  checkInLng       Float?           @map("check_in_lng")
  checkInAddress   String?          @map("check_in_address")
  checkInDistance  Float?           @map("check_in_distance")
  checkOut         DateTime?        @map("check_out")
  checkOutPhoto    String?          @map("check_out_photo")
  checkOutLat      Float?           @map("check_out_lat")
  checkOutLng      Float?           @map("check_out_lng")
  checkOutAddress  String?          @map("check_out_address")
  checkOutDistance Float?           @map("check_out_distance")
  status           AttendanceStatus @default(ON_TIME)
  lateMinutes      Int?             @map("late_minutes")
  note             String?
  isAutoCheckout   Boolean          @default(false) @map("is_auto_checkout")
  eventId          Int?             @map("event_id")
  deleteReason     String?          @map("delete_reason")
  isDeleted        Boolean          @default(false) @map("is_deleted")
  event            Event?           @relation(fields: [eventId], references: [eventId])
  location         Location?        @relation(fields: [locationId], references: [locationId])
  shift            Shift?           @relation(fields: [shiftId], references: [shiftId])
  user             User             @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("attendance")
}

model LeaveRequest {
  leaveId                                        Int         @id @default(autoincrement()) @map("leave_id")
  userId                                         Int         @map("user_id")
  leaveType                                      LeaveType   @map("leave_type")
  isHourly                                       Boolean     @default(false) @map("is_hourly")
  startDate                                      DateTime    @map("start_date") @db.Date
  endDate                                        DateTime    @map("end_date") @db.Date
  startTime                                      String?     @map("start_time")
  endTime                                        String?     @map("end_time")
  leaveHours                                     Float?      @map("leave_hours")
  reason                                         String?
  status                                         LeaveStatus @default(PENDING)
  attachmentUrl                                  String?     @map("attachment_url")
  medicalCertificateUrl                          String?     @map("medical_certificate_url") // ใบรับรองแพทย์ (สำหรับ SICK >= 3 วัน, MATERNITY, STERILIZATION)
  adminComment                                   String?     @map("admin_comment")
  numberOfDays                                   Int         @default(1) @map("number_of_days")
  paidDays                                       Int?        @map("paid_days") // จำนวนวันที่ได้รับค่าจ้าง (คำนวณตาม LeaveType)
  rejectionReason                                String?     @map("rejection_reason")
  deletedAt                                      DateTime?   @map("deleted_at") // Soft delete timestamp
  approvalActions                                ApprovalAction[]
  user                                           User        @relation("Requester", fields: [userId], references: [userId], onDelete: Cascade)

  @@map("leave_requests")
}

model AuditLog {
  logId       Int      @id @default(autoincrement()) @map("log_id")
  userId      Int?     @map("user_id")
  action      String
  targetTable String   @map("target_table")
  targetId    Int      @map("target_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_on")
  user        User?    @relation(fields: [userId], references: [userId])

  @@map("audit_logs")
}

model Notification {
  notificationId Int      @id @default(autoincrement()) @map("notification_id")
  userId         Int      @map("user_id")
  message        String
  isRead         Boolean  @default(false) @map("is_read")
  user           User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("notifications")
}

model Location {
  locationId      Int             @id @default(autoincrement()) @map("location_id")
  locationName    String          @map("location_name")
  latitude        Float           @map("latitude")
  longitude       Float           @map("longitude")
  radius          Float           @default(100) @map("radius")
  userId          Int             @map("user_id")
  deleteReason    String?         @map("delete_reason")
  address         String?
  description     String?
  isActive        Boolean         @default(true) @map("is_active")
  locationType    LocationType    @default(OTHER) @map("location_type")
  purpose         LocationPurpose @default(WORK_SITE)
  attendances     Attendance[]
  events          Event[]
  creator         User            @relation("LocationCreator", fields: [userId], references: [userId], onDelete: Cascade)
  shifts          Shift[]

  @@map("locations")
}

model Shift {
  shiftId              Int          @id @default(autoincrement()) @map("shift_id")
  name                 String       @map("name")
  shiftType            ShiftType    @default(REGULAR) @map("shift_type")
  startTime            String       @map("start_time")
  endTime              String       @map("end_time")
  gracePeriodMinutes   Int          @default(15) @map("grace_period_minutes")
  lateThresholdMinutes Int          @default(30) @map("late_threshold_minutes")
  specificDays         DayOfWeek[]
  customDate           DateTime?    @map("custom_date") @db.Date
  locationId           Int?         @map("location_id")
  userId               Int          @map("user_id")
  isActive             Boolean      @default(true) @map("is_active")
  deleteReason         String?      @map("delete_reason")
  isDeleted            Boolean      @default(false) @map("is_deleted")
  attendances          Attendance[]
  location             Location?    @relation(fields: [locationId], references: [locationId])
  user                 User         @relation("UserShift", fields: [userId], references: [userId], onDelete: Cascade)

  @@map("shifts")
}

model EventParticipant {
  participantId Int      @id @default(autoincrement()) @map("participant_id")
  eventId       Int      @map("event_id")
  userId        Int?     @map("user_id")
  branchId      Int?     @map("branch_id")
  role          Role?
  branches      Branch?  @relation(fields: [branchId], references: [branchId], onDelete: Cascade)
  event         Event    @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  users         User?    @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("event_participants")
}

model Event {
  eventId                                Int                  @id @default(autoincrement()) @map("event_id")
  eventName                              String               @map("event_name")
  description                            String?
  locationId                             Int?                 @map("location_id")
  venueName                              String?              @map("venue_name")
  venueLatitude                          Float?               @map("venue_latitude")
  venueLongitude                         Float?               @map("venue_longitude")
  startDateTime                          DateTime             @map("start_date_time")
  endDateTime                            DateTime             @map("end_date_time")
  participantType                        EventParticipantType @default(ALL) @map("participant_type")
  isActive                               Boolean              @default(true) @map("is_active")
  createdByUserId                        Int                  @map("created_by_user_id")
  deleteReason                           String?              @map("delete_reason")
  attendance                             Attendance[]
  event_participants                     EventParticipant[]
  creator                                User                 @relation("events_created_by_user_idTousers", fields: [createdByUserId], references: [userId], onDelete: Cascade)
  location                               Location?            @relation(fields: [locationId], references: [locationId], onDelete: SetNull)

  @@map("events")
}

model LateRequest {
  lateRequestId                                Int            @id @default(autoincrement()) @map("late_request_id")
  userId                                       Int            @map("user_id")
  attendanceId                                 Int?           @map("attendance_id")
  requestDate                                  DateTime       @db.Date @map("request_date")
  scheduledTime                                String         @map("scheduled_time")
  actualTime                                   String         @map("actual_time")
  lateMinutes                                  Int            @map("late_minutes")
  reason                                       String
  status                                       ApprovalStatus @default(PENDING)
  attachmentUrl                                String?        @map("attachment_url")
  adminComment                                 String?        @map("admin_comment")
  rejectionReason                              String?        @map("rejection_reason")
  deletedAt                                    DateTime?      @map("deleted_at")
  approvalActions                              ApprovalAction[]
  user                                         User           @relation("late_requests_user_idTousers", fields: [userId], references: [userId], onDelete: Cascade)

  @@map("late_requests")
}

enum Role {
  SUPERADMIN
  ADMIN
  MANAGER
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  RESIGNED
}

enum Gender {
  MALE
  FEMALE
}

enum Title {
  MR      // นาย
  MRS     // นาง
  MISS    // นางสาว
}

enum AttendanceStatus {
  ON_TIME
  LATE
  LATE_APPROVED // มาสายแต่ได้รับการอนุมัติคำขอมาสายแล้ว
  ABSENT
  LEAVE_APPROVED  // ลาได้รับอนุมัติแล้ว แต่มาเข้างานจริง (ถือว่า on-time)
}

enum LeaveType {
  SICK              // ลาป่วย - ได้รับค่าจ้างไม่เกิน 30 วันต่อปี
  PERSONAL          // ลากิจธุระอันจำเป็น - ไม่น้อยกว่า 3 วัน, ได้รับค่าจ้างไม่เกิน 3 วันต่อปี
  VACATION          // ลาพักร้อน - 6 วันต่อปี, ได้รับค่าจ้าง, สะสมได้
  MILITARY          // ลาเพื่อรับราชการทหาร - ได้รับค่าจ้างไม่เกิน 60 วันต่อปี
  TRAINING          // ลาเพื่อฝึกอบรม - ตามข้อบังคับบริษัท, ไม่ได้รับค่าจ้าง
  MATERNITY         // ลาคลอดบุตร - ไม่เกิน 98 วัน, ได้รับค่าจ้างจากนายจ้าง 45 วัน (เฉพาะหญิง)
  STERILIZATION     // ลาทำหมัน - ตามระยะเวลาที่แพทย์กำหนด, ได้รับค่าจ้าง
  ORDINATION        // ลาบวช - ไม่เกิน 120 วัน, ได้รับค่าจ้าง (เฉพาะชาย)
  PATERNITY         // ลาเพื่อช่วยเหลือภริยาคลอดบุตร - ไม่เกิน 15 วัน, ได้รับค่าจ้าง
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ShiftType {
  REGULAR
  SPECIFIC_DAY
  CUSTOM
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventParticipantType {
  ALL
  INDIVIDUAL
  BRANCH
  ROLE
}

enum LocationPurpose {
  WORK_SITE
  EVENT
}

enum LocationType {
  OFFICE
  BRANCH
  EVENT
  SITE
  MEETING
  OTHER
}

model Session {
  id                       Int     @id @default(autoincrement())
  userId                   Int     @map("user_id")
  token                    String  @unique
  expiresAt                DateTime @map("expires_at")
  refreshToken             String  @unique
  refreshTokenExpiresAt    DateTime @map("refresh_token_expires_at")
  createdAt                DateTime @default(now()) @map("created_on")
  ipAddress                String? @map("ip_address")
  userAgent                String? @map("user_agent")
  
  user      User    @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([token])
  @@index([refreshToken])
  @@index([userId])
  @@index([expiresAt])
  @@index([refreshTokenExpiresAt])
  @@map("sessions")
}

model ApprovalAction {
  approvalActionId Int                @id @default(autoincrement()) @map("approval_action_id")
  leaveId          Int?               @map("leave_id")
  lateRequestId    Int?               @map("late_request_id")
  actorUserId      Int                @map("actor_user_id")
  action           ApprovalActionType
  adminComment     String?            @map("admin_comment")
  rejectionReason  String?            @map("rejection_reason")
  actor            User               @relation(fields: [actorUserId], references: [userId], onDelete: Cascade)
  leaveRequest     LeaveRequest?      @relation(fields: [leaveId], references: [leaveId], onDelete: Cascade)
  lateRequest      LateRequest?       @relation(fields: [lateRequestId], references: [lateRequestId], onDelete: Cascade)

  @@index([leaveId, approvalActionId])
  @@index([lateRequestId, approvalActionId])
  @@index([actorUserId])
  @@map("approval_actions")
}

model Announcement {
  announcementId        Int                    @id @default(autoincrement()) @map("announcement_id")
  title                 String                 @map("title")
  content               String                 @map("content")
  targetRoles           Role[]                 @default([]) // บุคลากรประเภท เว้นไว้ = EVERYONE
  targetBranchIds       Int[]                  @default([]) @map("target_branch_ids") // สาขาเฉพาะ เว้นไว้ = EVERYONE
  targetUserIds         Int[]                  @default([]) @map("target_user_ids") // ระบุ userId เฉพาะ เว้นไว้ = ใช้ role/branch filter
  status                AnnouncementStatus     @default(DRAFT) @map("status")
  createdByUserId       Int                    @map("created_by_user_id")
  sentByUserId          Int?                   @map("sent_by_user_id")
  deleteReason          String?                @map("delete_reason")

  creator               User                   @relation("AnnouncementCreator", fields: [createdByUserId], references: [userId], onDelete: Cascade)
  sentBy                User?                  @relation("AnnouncementSender", fields: [sentByUserId], references: [userId])
  recipients            AnnouncementRecipient[]

  @@map("announcements")
}

model AnnouncementRecipient {
  recipientId           Int                    @id @default(autoincrement()) @map("recipient_id")
  announcementId        Int                    @map("announcement_id")
  userId                Int                    @map("user_id")
  announcement          Announcement           @relation(fields: [announcementId], references: [announcementId], onDelete: Cascade)
  user                  User                   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("announcement_recipients")
}

enum AnnouncementStatus {
  DRAFT
  SENT
}

enum ApprovalActionType {
  APPROVED
  REJECTED
}
