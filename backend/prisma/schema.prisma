generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  userId                                                  Int                  @id @default(autoincrement()) @map("user_id")
  employeeId                                              String               @unique @map("employee_id")
  title                                                   Title                @default(MR) @map("title")
  firstName                                               String               @map("first_name")
  lastName                                                String               @map("last_name")
  nickname                                                String?              @map("nickname")
  gender                                                  Gender               @default(MALE)
  nationalId                                              String               @unique @map("national_id")
  emergent_tel                                            String               @map("emergent_tel")
  emergent_first_name                                     String               @map("emergent_first_name")
  emergent_last_name                                      String               @map("emergent_last_name")
  emergent_relation                                       String               @map("emergent_relation")
  phone                                                   String               @map("phone")
  email                                                   String               @unique
  password                                                String               @map("password")
  customPassword                                          String?              @map("custom_password")
  adminPassword                                           String?              @map("admin_password")
  avatarUrl                                               String?              @map("avatar_url")
  birthDate                                               DateTime?            @map("birth_date") @db.Date
  branchId                                                Int?                 @map("branch_id")
  role                                                    Role                 @default(USER)
  status                                                  UserStatus           @default(ACTIVE)
  createdAt                                               DateTime             @default(now()) @map("created_at")
  updatedAt                                               DateTime             @default(now()) @updatedAt @map("updated_at")
  updatedByUserId                                         Int?                 @map("updated_by_user_id")
  attendances                                             Attendance[]
  auditLogs                                               AuditLog[]
  branchesCreated                                         Branch[]             @relation("BranchCreator")
  branchesDeleted                                         Branch[]             @relation("BranchDeleter")
  branchesUpdated                                         Branch[]             @relation("BranchUpdater")
  downloadLogs                                            DownloadLog[]
  EventParticipants                                       EventParticipant[]
  events_events_created_by_user_idTousers                 Event[]              @relation("events_created_by_user_idTousers")
  events_events_deleted_by_user_idTousers                 Event[]              @relation("events_deleted_by_user_idTousers")
  events_events_updated_by_user_idTousers                 Event[]              @relation("events_updated_by_user_idTousers")
  late_requests_late_requests_approved_by_user_idTousers  LateRequest[]        @relation("late_requests_approved_by_user_idTousers")
  late_requests_late_requests_deleted_by_user_idTousers   LateRequest[]        @relation("late_requests_deleted_by_user_idTousers")
  late_requests_late_requests_updated_by_user_idTousers   LateRequest[]        @relation("late_requests_updated_by_user_idTousers")
  late_requests_late_requests_user_idTousers              LateRequest[]        @relation("late_requests_user_idTousers")
  approvedLeaves                                          LeaveRequest[]       @relation("Approver")
  leave_requests_leave_requests_deleted_by_user_idTousers LeaveRequest[]       @relation("leave_requests_deleted_by_user_idTousers")
  leave_requests_leave_requests_updated_by_user_idTousers LeaveRequest[]       @relation("leave_requests_updated_by_user_idTousers")
  leaveRequests                                           LeaveRequest[]       @relation("Requester")
  locationsDeleted                                        Location[]           @relation("LocationDeleter")
  locationsUpdated                                        Location[]           @relation("LocationUpdater")
  locationsCreated                                        Location[]           @relation("LocationCreator")
  notifications                                           Notification[]
  shiftsCreated                                           Shift[]              @relation("ShiftCreator")
  shiftsDeleted                                           Shift[]              @relation("ShiftDeleter")
  shiftsUpdated                                           Shift[]              @relation("ShiftUpdater")
  shifts                                                  Shift[]              @relation("UserShift")
  branch                                                  Branch?              @relation("UserBranch", fields: [branchId], references: [branchId])
  updatedBy                                               User?                @relation("UserUpdater", fields: [updatedByUserId], references: [userId])
  usersUpdated                                            User[]               @relation("UserUpdater")
  passwordResets                                          PasswordReset[]
  sessions                                                Session[]
  
  // Announcement Relations
  createdAnnouncements                                    Announcement[]       @relation("AnnouncementCreator")
  updatedAnnouncements                                    Announcement[]       @relation("AnnouncementUpdater")
  sentAnnouncements                                       Announcement[]       @relation("AnnouncementSender")
  announcementRecipients                                  AnnouncementRecipient[]

  @@map("users")
}

model Branch {
  branchId           Int                  @id @default(autoincrement()) @map("branch_id")
  name               String               @map("name")
  code               String               @unique @map("code")
  address            String?              @map("address")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @default(now()) @updatedAt @map("updated_at")
  createdByUserId    Int?                 @map("created_by_user_id")
  updatedByUserId    Int?                 @map("updated_by_user_id")
  deletedAt          DateTime?            @map("deleted_at")
  deletedByUserId    Int?                 @map("deleted_by_user_id")
  creator            User?                @relation("BranchCreator", fields: [createdByUserId], references: [userId])
  deletedBy          User?                @relation("BranchDeleter", fields: [deletedByUserId], references: [userId])
  updatedBy          User?                @relation("BranchUpdater", fields: [updatedByUserId], references: [userId])
  EventParticipants  EventParticipant[]
  users              User[]               @relation("UserBranch")

  @@map("branches")
}

model Attendance {
  attendanceId     Int              @id @default(autoincrement()) @map("attendance_id")
  userId           Int              @map("user_id")
  shiftId          Int?             @map("shift_id")
  locationId       Int?             @map("location_id")
  checkIn          DateTime         @default(now()) @map("check_in")
  checkInPhoto     String?          @map("check_in_photo")
  checkInLat       Float?           @map("check_in_lat")
  checkInLng       Float?           @map("check_in_lng")
  checkInAddress   String?          @map("check_in_address")
  checkInDistance  Float?           @map("check_in_distance")
  checkOut         DateTime?        @map("check_out")
  checkOutPhoto    String?          @map("check_out_photo")
  checkOutLat      Float?           @map("check_out_lat")
  checkOutLng      Float?           @map("check_out_lng")
  checkOutAddress  String?          @map("check_out_address")
  checkOutDistance Float?           @map("check_out_distance")
  status           AttendanceStatus @default(ON_TIME)
  lateMinutes      Int?             @map("late_minutes")
  note             String?
  isAutoCheckout   Boolean          @default(false) @map("is_auto_checkout")
  createdAt        DateTime         @default(now()) @map("created_at")
  eventId          Int?             @map("event_id")
  deleteReason     String?          @map("delete_reason")
  deletedAt        DateTime?        @map("deleted_at")
  deletedByUserId  Int?             @map("deleted_by_user_id")
  event            Event?           @relation(fields: [eventId], references: [eventId])
  location         Location?        @relation(fields: [locationId], references: [locationId])
  shift            Shift?           @relation(fields: [shiftId], references: [shiftId])
  user             User             @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("attendance")
}

model LeaveRequest {
  leaveId                                        Int         @id @default(autoincrement()) @map("leave_id")
  userId                                         Int         @map("user_id")
  leaveType                                      LeaveType   @map("leave_type")
  startDate                                      DateTime    @map("start_date") @db.Date
  endDate                                        DateTime    @map("end_date") @db.Date
  reason                                         String?
  status                                         LeaveStatus @default(PENDING)
  attachmentUrl                                  String?     @map("attachment_url")
  medicalCertificateUrl                          String?     @map("medical_certificate_url") // ใบรับรองแพทย์ (สำหรับ SICK >= 3 วัน, MATERNITY, STERILIZATION)
  approvedByUserId                               Int?        @map("approved_by_user_id")
  adminComment                                   String?     @map("admin_comment")
  createdAt                                      DateTime    @default(now()) @map("created_at")
  updatedAt                                      DateTime    @default(now()) @updatedAt @map("updated_at")
  approvedAt                                     DateTime?   @map("approved_at")
  numberOfDays                                   Int         @default(1) @map("number_of_days")
  paidDays                                       Int?        @map("paid_days") // จำนวนวันที่ได้รับค่าจ้าง (คำนวณตาม LeaveType)
  rejectionReason                                String?     @map("rejection_reason")
  deletedAt                                      DateTime?   @map("deleted_at")
  deletedByUserId                                Int?        @map("deleted_by_user_id")
  updatedByUserId                                Int?        @map("updated_by_user_id")
  approver                                       User?       @relation("Approver", fields: [approvedByUserId], references: [userId])
  users_leave_requests_deleted_by_user_idTousers User?       @relation("leave_requests_deleted_by_user_idTousers", fields: [deletedByUserId], references: [userId])
  users_leave_requests_updated_by_user_idTousers User?       @relation("leave_requests_updated_by_user_idTousers", fields: [updatedByUserId], references: [userId])
  user                                           User        @relation("Requester", fields: [userId], references: [userId], onDelete: Cascade)

  @@map("leave_requests")
}

model AuditLog {
  logId       Int      @id @default(autoincrement()) @map("log_id")
  userId      Int?     @map("user_id")
  action      String
  targetTable String   @map("target_table")
  targetId    Int      @map("target_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User?    @relation(fields: [userId], references: [userId])

  @@map("audit_logs")
}

model Notification {
  notificationId Int      @id @default(autoincrement()) @map("notification_id")
  userId         Int      @map("user_id")
  message        String
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("notifications")
}

model DownloadLog {
  logId      Int      @id @default(autoincrement()) @map("log_id")
  userId     Int      @map("user_id")
  fileName   String   @map("file_name")
  reportType String   @map("report_type")
  downloadAt DateTime @default(now()) @map("download_at")
  user       User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("download_logs")
}

model Location {
  locationId      Int             @id @default(autoincrement()) @map("location_id")
  locationName    String          @map("location_name")
  latitude        Float           @map("latitude")
  longitude       Float           @map("longitude")
  radius          Float           @default(100) @map("radius")
  userId          Int             @map("user_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at")
  updatedByUserId Int?            @map("updated_by_user_id")
  deletedAt       DateTime?       @map("deleted_at")
  deletedByUserId Int?            @map("deleted_by_user_id")
  deleteReason    String?         @map("delete_reason")
  address         String?
  description     String?
  isActive        Boolean         @default(true) @map("is_active")
  locationType    LocationType    @default(OTHER) @map("location_type")
  purpose         LocationPurpose @default(WORK_SITE)
  attendances     Attendance[]
  events          Event[]
  deletedBy       User?           @relation("LocationDeleter", fields: [deletedByUserId], references: [userId])
  updatedBy       User?           @relation("LocationUpdater", fields: [updatedByUserId], references: [userId])
  creator         User            @relation("LocationCreator", fields: [userId], references: [userId], onDelete: Cascade)
  shifts          Shift[]

  @@map("locations")
}

model Shift {
  shiftId              Int          @id @default(autoincrement()) @map("shift_id")
  name                 String       @map("name")
  shiftType            ShiftType    @default(REGULAR) @map("shift_type")
  startTime            String       @map("start_time")
  endTime              String       @map("end_time")
  gracePeriodMinutes   Int          @default(15) @map("grace_period_minutes")
  lateThresholdMinutes Int          @default(30) @map("late_threshold_minutes")
  specificDays         DayOfWeek[]
  customDate           DateTime?    @map("custom_date") @db.Date
  locationId           Int?         @map("location_id")
  userId               Int          @map("user_id")
  isActive             Boolean      @default(true) @map("is_active")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @default(now()) @updatedAt @map("updated_at")
  createdByUserId      Int?         @map("created_by_user_id")
  updatedByUserId      Int?         @map("updated_by_user_id")
  deletedAt            DateTime?    @map("deleted_at")
  deletedByUserId      Int?         @map("deleted_by_user_id")
  deleteReason         String?      @map("delete_reason")
  attendances          Attendance[]
  creator              User?        @relation("ShiftCreator", fields: [createdByUserId], references: [userId])
  deletedBy            User?        @relation("ShiftDeleter", fields: [deletedByUserId], references: [userId])
  location             Location?    @relation(fields: [locationId], references: [locationId])
  updatedBy            User?        @relation("ShiftUpdater", fields: [updatedByUserId], references: [userId])
  user                 User         @relation("UserShift", fields: [userId], references: [userId], onDelete: Cascade)

  @@map("shifts")
}

model EventParticipant {
  participantId Int      @id @default(autoincrement()) @map("participant_id")
  eventId       Int      @map("event_id")
  userId        Int?     @map("user_id")
  branchId      Int?     @map("branch_id")
  role          Role?
  createdAt     DateTime @default(now()) @map("created_at")
  branches      Branch?  @relation(fields: [branchId], references: [branchId], onDelete: Cascade)
  event         Event    @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  users         User?    @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("event_participants")
}

model Event {
  eventId                                Int                  @id @default(autoincrement()) @map("event_id")
  eventName                              String               @map("event_name")
  description                            String?
  locationId                             Int?                 @map("location_id")
  venueName                              String?              @map("venue_name")
  venueLatitude                          Float?               @map("venue_latitude")
  venueLongitude                         Float?               @map("venue_longitude")
  startDateTime                          DateTime             @map("start_date_time")
  endDateTime                            DateTime             @map("end_date_time")
  participantType                        EventParticipantType @default(ALL) @map("participant_type")
  isActive                               Boolean              @default(true) @map("is_active")
  createdByUserId                        Int                  @map("created_by_user_id")
  createdAt                              DateTime             @default(now()) @map("created_at")
  updatedByUserId                        Int?                 @map("updated_by_user_id")
  updatedAt                              DateTime             @default(now()) @map("updated_at")
  deletedAt                              DateTime?            @map("deleted_at")
  deletedByUserId                        Int?                 @map("deleted_by_user_id")
  deleteReason                           String?              @map("delete_reason")
  attendance                             Attendance[]
  event_participants                     EventParticipant[]
  creator                                User                 @relation("events_created_by_user_idTousers", fields: [createdByUserId], references: [userId], onDelete: Cascade)
  deletedBy                              User?                @relation("events_deleted_by_user_idTousers", fields: [deletedByUserId], references: [userId])
  location                               Location?            @relation(fields: [locationId], references: [locationId], onDelete: SetNull)
  updatedBy                              User?                @relation("events_updated_by_user_idTousers", fields: [updatedByUserId], references: [userId])

  @@map("events")
}

model LateRequest {
  lateRequestId                                Int            @id @default(autoincrement()) @map("late_request_id")
  userId                                       Int            @map("user_id")
  attendanceId                                 Int?           @map("attendance_id")
  requestDate                                  DateTime       @db.Date @map("request_date")
  scheduledTime                                String         @map("scheduled_time")
  actualTime                                   String         @map("actual_time")
  lateMinutes                                  Int            @map("late_minutes")
  reason                                       String
  status                                       ApprovalStatus @default(PENDING)
  attachmentUrl                                String?        @map("attachment_url")
  approvedByUserId                             Int?           @map("approved_by_user_id")
  adminComment                                 String?        @map("admin_comment")
  approvedAt                                   DateTime?      @map("approved_at")
  rejectionReason                              String?        @map("rejection_reason")
  createdAt                                    DateTime       @default(now()) @map("created_at")
  updatedAt                                    DateTime       @default(now()) @map("updated_at")
  deletedAt                                    DateTime?      @map("deleted_at")
  deletedByUserId                              Int?           @map("deleted_by_user_id")
  updatedByUserId                              Int?           @map("updated_by_user_id")
  approver                                     User?          @relation("late_requests_approved_by_user_idTousers", fields: [approvedByUserId], references: [userId])
  deletedBy                                    User?          @relation("late_requests_deleted_by_user_idTousers", fields: [deletedByUserId], references: [userId])
  updatedBy                                    User?          @relation("late_requests_updated_by_user_idTousers", fields: [updatedByUserId], references: [userId])
  user                                         User           @relation("late_requests_user_idTousers", fields: [userId], references: [userId], onDelete: Cascade)

  @@map("late_requests")
}

model PasswordReset {
  resetId   Int      @id @default(autoincrement()) @map("reset_id")
  userId    Int      @map("user_id")
  token     String   @unique @map("token")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  isUsed    Boolean  @default(false) @map("is_used")
  usedAt    DateTime? @map("used_at")
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("password_resets")
}

enum Role {
  SUPERADMIN
  ADMIN
  MANAGER
  USER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  RESIGNED
}

enum Gender {
  MALE
  FEMALE
}

enum Title {
  MR      // นาย
  MRS     // นาง
  MISS    // นางสาว
}

enum AttendanceStatus {
  ON_TIME
  LATE
  ABSENT
  LEAVE_APPROVED  // ลาได้รับอนุมัติแล้ว แต่มาเข้างานจริง (ถือว่า on-time)
}

enum LeaveType {
  SICK              // ลาป่วย - ได้รับค่าจ้างไม่เกิน 30 วันต่อปี
  PERSONAL          // ลากิจ - ตามข้อบังคับ
  VACATION          // ลาพักร้อน - 6 วันต่อปี, ได้รับค่าจ้าง, สะสมได้
  MILITARY          // ลาเพื่อรับราชการทหาร - ได้รับค่าจ้างไม่เกิน 60 วันต่อปี (เฉพาะชาย)
  TRAINING          // ลาเพื่อฝึกอบรม - ไม่ได้รับค่าจ้าง
  MATERNITY         // ลาคลอด - ไม่เกิน 90 วัน, ได้รับค่าจ้างไม่เกิน 45 วัน (เฉพาะหญิง)
  STERILIZATION     // ลาเพื่อทำหมัน - ตามที่แพทย์กำหนด, ได้รับค่าจ้าง
  ORDINATION        // ลาบวช - ไม่เกิน 120 วัน (เฉพาะชาย)
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ShiftType {
  REGULAR
  SPECIFIC_DAY
  CUSTOM
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventParticipantType {
  ALL
  INDIVIDUAL
  BRANCH
  ROLE
}

enum LocationPurpose {
  WORK_SITE
  EVENT
}

enum LocationType {
  OFFICE
  BRANCH
  EVENT
  SITE
  MEETING
  OTHER
}

model Session {
  id                       Int     @id @default(autoincrement())
  userId                   Int     @map("user_id")
  token                    String  @unique
  expiresAt                DateTime @map("expires_at")
  refreshToken             String  @unique
  refreshTokenExpiresAt    DateTime @map("refresh_token_expires_at")
  createdAt                DateTime @default(now()) @map("created_at")
  ipAddress                String? @map("ip_address")
  userAgent                String? @map("user_agent")
  
  user      User    @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([token])
  @@index([refreshToken])
  @@index([userId])
  @@index([expiresAt])
  @@index([refreshTokenExpiresAt])
  @@map("sessions")
}

model Announcement {
  announcementId        Int                    @id @default(autoincrement()) @map("announcement_id")
  title                 String                 @map("title")
  content               String                 @map("content")
  targetRoles           Role[]                 @default([]) // บุคลากรประเภท เว้นไว้ = EVERYONE
  targetBranchIds       Int[]                  @default([]) @map("target_branch_ids") // สาขาเฉพาะ เว้นไว้ = EVERYONE
  targetUserIds         Int[]                  @default([]) @map("target_user_ids") // ระบุ userId เฉพาะ เว้นไว้ = ใช้ role/branch filter
  status                AnnouncementStatus     @default(DRAFT) @map("status")
  createdByUserId       Int                    @map("created_by_user_id")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedByUserId       Int?                   @map("updated_by_user_id")
  updatedAt             DateTime               @default(now()) @updatedAt @map("updated_at")
  sentAt                DateTime?              @map("sent_at")
  sentByUserId          Int?                   @map("sent_by_user_id")
  deletedAt             DateTime?              @map("deleted_at")
  deleteReason          String?                @map("delete_reason")

  creator               User                   @relation("AnnouncementCreator", fields: [createdByUserId], references: [userId], onDelete: Cascade)
  updatedBy             User?                  @relation("AnnouncementUpdater", fields: [updatedByUserId], references: [userId])
  sentBy                User?                  @relation("AnnouncementSender", fields: [sentByUserId], references: [userId])
  recipients            AnnouncementRecipient[]

  @@map("announcements")
}

model AnnouncementRecipient {
  recipientId           Int                    @id @default(autoincrement()) @map("recipient_id")
  announcementId        Int                    @map("announcement_id")
  userId                Int                    @map("user_id")
  sentAt                DateTime?              @map("sent_at")
  createdAt             DateTime               @default(now()) @map("created_at")

  announcement          Announcement           @relation(fields: [announcementId], references: [announcementId], onDelete: Cascade)
  user                  User                   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("announcement_recipients")
}

enum AnnouncementStatus {
  DRAFT
  SENT
}
