# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=easycheck

# Prisma Database URLs
DATABASE_URL="postgresql://postgres:your_secure_password@postgres:5432/easycheck?schema=public&pgbouncer=true"
DIRECT_URL="postgresql://postgres:your_secure_password@postgres:5432/easycheck?schema=public"

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_anon_key

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000
